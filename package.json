{
  "name": "react-image-and-background-image-fade-website",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:package": "npm --prefix ../react-image-and-background-image-fade run build",
    "predev": "npm run build:package",
    "dev": "next dev --webpack",
    "prebuild": "npm run build:package",
    "build": "next build --webpack",
    "start": "serve out -l 3006",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "check": "npm run typecheck && npm run lint && npm test && npm run build && npm run test:e2e"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.2.6",
    "lucide-react": "^1.14.0",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-image-and-background-image-fade": "file:../react-image-and-background-image-fade",
    "shiki": "^4.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.2.6",
    "serve": "^14.2.5",
    "typescript": "^6.0.3",
    "vitest": "^4.0.8"
  },
  "overrides": {
    "brace-expansion": "^1.1.13",
    "minimist": "^1.2.8",
    "postcss": "^8.5.10"
  }
}
